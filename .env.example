# Copy to .env.local and fill in the values from your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only. Found in Supabase Dashboard → Settings → API keys → service_role (secret).
# Never expose this to the browser.
SUPABASE_SECRET_KEY=
