# Copy to .env.local and fill in the values from your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only. Found in Supabase Dashboard → Settings → API keys → service_role (secret).
# Never expose this to the browser.
SUPABASE_SECRET_KEY=

# Optional. Server-only key used to encrypt opaque flag-proxy tokens (anti-cheat).
# Falls back to SUPABASE_SECRET_KEY when unset. Set a distinct value to rotate
# flag tokens without rotating the service-role key.
FLAG_TOKEN_SECRET=
